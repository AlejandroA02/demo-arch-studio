---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ATELIER — Architecture Studio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,700;1,6..96,400&family=Karla:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Fixed nav -->
    <nav class="site-nav">
      <div class="nav-brand">ATELIER</div>
      <div class="nav-meta">Architecture & Interior Design</div>
    </nav>

    <!-- ══════ 1. HERO (full width) ══════ -->
    <section class="hero">
      <div class="hero-grid-lines">
        <div class="hgl hgl-v1"></div>
        <div class="hgl hgl-v2"></div>
        <div class="hgl hgl-v3"></div>
        <div class="hgl hgl-h1"></div>
        <div class="hgl hgl-h2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-eyebrow">Est. 2019 — Miami, FL</div>
        <h1 class="hero-title">ATELIER</h1>
        <p class="hero-sub">We shape space. Space shapes life.</p>
        <div class="hero-scroll-cue">
          <span>Scroll</span>
          <div class="scroll-bar"><div class="scroll-bar-fill"></div></div>
        </div>
      </div>
    </section>

    <!-- ══════ 2. VERTICAL SPLIT — left up / right down ══════ -->
    <section class="vsplit" data-split="vertical">
      <div class="vsplit-left">
        <div class="panel-label">
          <span class="label-num">01</span>
          <span class="label-line"></span>
          <span>Philosophy</span>
        </div>
        <blockquote class="panel-quote">
          &ldquo;Architecture should speak of its time and place, but yearn for timelessness.&rdquo;
        </blockquote>
        <p class="panel-body">We believe in the quiet power of considered space. Every line we draw serves the dialogue between structure and the human experience within it.</p>
      </div>
      <div class="vsplit-right">
        <div class="visual-block block-facade">
          <div class="facade-window"></div>
          <div class="facade-window"></div>
          <div class="facade-window"></div>
          <div class="facade-window"></div>
          <div class="facade-window"></div>
          <div class="facade-window"></div>
          <div class="facade-beam"></div>
          <div class="facade-beam facade-beam-2"></div>
        </div>
      </div>
      <div class="split-line split-line-v"></div>
    </section>

    <!-- ══════ 3. HORIZONTAL SPLIT — top left / bottom right ══════ -->
    <section class="hsplit" data-split="horizontal">
      <div class="hsplit-top">
        <div class="visual-block block-section">
          <div class="section-floor section-floor-1"></div>
          <div class="section-floor section-floor-2"></div>
          <div class="section-floor section-floor-3"></div>
          <div class="section-col section-col-1"></div>
          <div class="section-col section-col-2"></div>
          <div class="section-roof"></div>
        </div>
      </div>
      <div class="hsplit-bottom">
        <div class="panel-label">
          <span class="label-num">02</span>
          <span class="label-line"></span>
          <span>Meridian House</span>
        </div>
        <h2 class="panel-heading">Light as<br/>Material</h2>
        <p class="panel-body">Miami Beach, FL — 2024. A residence where every room is a dialogue with the sun. Deep overhangs, pivoting walls, and courtyards that pull the sky inside.</p>
      </div>
      <div class="split-line split-line-h"></div>
    </section>

    <!-- ══════ 4. VERTICAL SPLIT — reversed (right up / left down) ══════ -->
    <section class="vsplit vsplit-reversed" data-split="vertical-reverse">
      <div class="vsplit-left">
        <div class="visual-block block-plan">
          <div class="plan-room plan-room-1"></div>
          <div class="plan-room plan-room-2"></div>
          <div class="plan-room plan-room-3"></div>
          <div class="plan-wall plan-wall-1"></div>
          <div class="plan-wall plan-wall-2"></div>
          <div class="plan-wall plan-wall-3"></div>
          <div class="plan-door"></div>
        </div>
      </div>
      <div class="vsplit-right">
        <div class="panel-label">
          <span class="label-num">03</span>
          <span class="label-line"></span>
          <span>Terra Office Tower</span>
        </div>
        <h2 class="panel-heading">Vertical<br/>Ambition</h2>
        <p class="panel-body">Brickell, FL — 2023. A commercial tower that breathes, with deep-set loggias and a structural grid that doubles as sun control.</p>
      </div>
      <div class="split-line split-line-v"></div>
    </section>

    <!-- ══════ 5. HORIZONTAL SPLIT — reversed (top right / bottom left) ══════ -->
    <section class="hsplit hsplit-reversed" data-split="horizontal-reverse">
      <div class="hsplit-top">
        <div class="panel-label">
          <span class="label-num">04</span>
          <span class="label-line"></span>
          <span>Our Process</span>
        </div>
        <div class="process-list">
          <div class="process-item">
            <span class="process-num">01</span>
            <div><h3>CONCEPT</h3><p>Listening, researching, distilling the project into a clear vision.</p></div>
          </div>
          <div class="process-item">
            <span class="process-num">02</span>
            <div><h3>DESIGN</h3><p>Translating ideas into precise drawings, models, and material palettes.</p></div>
          </div>
          <div class="process-item">
            <span class="process-num">03</span>
            <div><h3>BUILD</h3><p>Overseeing every detail from foundation to finish with uncompromising craft.</p></div>
          </div>
        </div>
      </div>
      <div class="hsplit-bottom">
        <div class="visual-block block-detail">
          <div class="detail-beam"></div>
          <div class="detail-beam detail-beam-2"></div>
          <div class="detail-joint"></div>
          <div class="detail-bolt"></div>
          <div class="detail-bolt detail-bolt-2"></div>
          <div class="detail-line detail-line-1"></div>
          <div class="detail-line detail-line-2"></div>
          <div class="detail-dimension"></div>
        </div>
      </div>
      <div class="split-line split-line-h"></div>
    </section>

    <!-- ══════ 6. VERTICAL SPLIT — awards / elevation ══════ -->
    <section class="vsplit" data-split="vertical">
      <div class="vsplit-left">
        <div class="panel-label">
          <span class="label-num">05</span>
          <span class="label-line"></span>
          <span>Recognition</span>
        </div>
        <div class="awards-compact">
          <div class="award-line"><span class="award-yr">2024</span>AIA Miami Honor Award</div>
          <div class="award-line"><span class="award-yr">2024</span>Architizer A+ Jury Winner</div>
          <div class="award-line"><span class="award-yr">2023</span>Interior Design Best of Year</div>
          <div class="award-line"><span class="award-yr">2023</span>Azure Magazine AZ Award</div>
          <div class="award-line"><span class="award-yr">2022</span>Dezeen Awards Longlist</div>
        </div>
      </div>
      <div class="vsplit-right">
        <div class="visual-block block-elevation">
          <div class="elev-base"></div>
          <div class="elev-floor elev-floor-1"></div>
          <div class="elev-floor elev-floor-2"></div>
          <div class="elev-floor elev-floor-3"></div>
          <div class="elev-cantilever"></div>
          <div class="elev-glass"></div>
          <div class="elev-glass elev-glass-2"></div>
        </div>
      </div>
      <div class="split-line split-line-v"></div>
    </section>

    <!-- ══════ 7. CONTACT (full width, dark) ══════ -->
    <section class="contact-section">
      <div class="contact-inner">
        <div class="contact-left">
          <h2 class="contact-headline">Let&rsquo;s build<br/>something<br/>extraordinary.</h2>
        </div>
        <div class="contact-right">
          <div class="contact-block">
            <span class="contact-label">Studio</span>
            <p>3400 NW 2nd Avenue, Suite 210<br/>Miami, FL 33127</p>
          </div>
          <div class="contact-block">
            <span class="contact-label">Email</span>
            <p>hello@atelier.studio</p>
          </div>
          <div class="contact-block">
            <span class="contact-label">Phone</span>
            <p>+1 (305) 555-0172</p>
          </div>
          <div class="contact-footer">
            <span>&copy; 2024 Atelier Architecture Studio</span>
          </div>
        </div>
      </div>
    </section>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --cream: #f5f2ed;
        --stone: #d4cdc4;
        --stone-light: #e8e4de;
        --charcoal: #1a1a1a;
        --bronze: #8b7335;
        --text-primary: #1a1a1a;
        --text-secondary: #6b6560;
        --text-tertiary: #9e9790;
        --border: rgba(26,26,26,0.08);
        --border-strong: rgba(26,26,26,0.12);
        --font-display: 'Bodoni Moda', 'Georgia', serif;
        --font-body: 'Karla', 'Helvetica Neue', sans-serif;
      }

      html { background: var(--cream); }

      body {
        font-family: var(--font-body);
        color: var(--text-primary);
        background: var(--cream);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      /* Paper grain */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 10000;
        pointer-events: none;
        opacity: 0.025;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 200px 200px;
      }

      html.lenis, html.lenis body { height: auto; }
      .lenis.lenis-smooth { scroll-behavior: auto !important; }

      /* ── NAV ── */
      .site-nav {
        position: fixed;
        top: 0; left: 0; right: 0;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 3.5rem;
        mix-blend-mode: difference;
        pointer-events: none;
      }

      .nav-brand {
        font-family: var(--font-display);
        font-size: 1rem;
        letter-spacing: 0.35em;
        color: white;
        pointer-events: auto;
      }

      .nav-meta {
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.5);
      }

      /* ══ HERO ══ */
      .hero {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      .hero-grid-lines { position: absolute; inset: 0; pointer-events: none; }
      .hgl { position: absolute; background: var(--border); }
      .hgl-v1 { width: 1px; height: 100%; left: 50%; }
      .hgl-v2 { width: 1px; height: 60%; left: 25%; top: 20%; }
      .hgl-v3 { width: 1px; height: 60%; right: 25%; top: 20%; }
      .hgl-h1 { height: 1px; width: 100%; top: 50%; }
      .hgl-h2 { height: 1px; width: 60%; top: 35%; left: 20%; }

      .hero-content { text-align: center; position: relative; z-index: 2; }

      .hero-eyebrow {
        font-size: 0.68rem; font-weight: 500; letter-spacing: 0.3em;
        text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 1.5rem;
      }

      .hero-title {
        font-family: var(--font-display);
        font-size: clamp(5rem, 15vw, 14rem);
        font-weight: 400; letter-spacing: 0.12em; line-height: 0.85;
      }

      .hero-sub {
        font-family: var(--font-display);
        font-size: clamp(0.9rem, 1.8vw, 1.3rem);
        font-style: italic; color: var(--text-secondary); margin-top: 1.5rem;
      }

      .hero-scroll-cue {
        margin-top: 4rem; display: flex; flex-direction: column;
        align-items: center; gap: 0.75rem;
      }

      .hero-scroll-cue span {
        font-size: 0.6rem; letter-spacing: 0.25em;
        text-transform: uppercase; color: var(--text-tertiary);
      }

      .scroll-bar {
        width: 1px; height: 50px; background: var(--stone);
        position: relative; overflow: hidden;
      }

      .scroll-bar-fill {
        width: 100%; height: 100%; background: var(--bronze);
        animation: scroll-fill 2s ease-in-out infinite;
      }

      @keyframes scroll-fill {
        0% { transform: scaleY(0); transform-origin: top; }
        45% { transform: scaleY(1); transform-origin: top; }
        55% { transform: scaleY(1); transform-origin: bottom; }
        100% { transform: scaleY(0); transform-origin: bottom; }
      }

      /* ══════════════════════════════════════ */
      /* VERTICAL SPLITS                       */
      /* ══════════════════════════════════════ */
      .vsplit {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 100vh;
        position: relative;
        overflow: hidden;
      }

      .vsplit-left, .vsplit-right {
        padding: 8vh 5vw;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 100vh;
        will-change: transform;
      }

      .vsplit-left { background: var(--cream); }
      .vsplit-right { background: var(--stone-light); }

      .vsplit-reversed .vsplit-left { background: var(--stone-light); }
      .vsplit-reversed .vsplit-right { background: var(--cream); }

      /* ══════════════════════════════════════ */
      /* HORIZONTAL SPLITS                     */
      /* ══════════════════════════════════════ */
      .hsplit {
        display: grid;
        grid-template-rows: 1fr 1fr;
        min-height: 100vh;
        position: relative;
        overflow: hidden;
      }

      .hsplit-top, .hsplit-bottom {
        padding: 6vh 8vw;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 50vh;
        will-change: transform;
      }

      .hsplit-top { background: var(--stone-light); }
      .hsplit-bottom { background: var(--cream); }

      .hsplit-reversed .hsplit-top { background: var(--cream); }
      .hsplit-reversed .hsplit-bottom { background: var(--stone-light); }

      /* ── SPLIT LINES ── */
      .split-line {
        position: absolute;
        z-index: 5;
        pointer-events: none;
      }

      .split-line-v {
        top: 0; bottom: 0; left: 50%;
        width: 1px;
        background: linear-gradient(to bottom, transparent, var(--border-strong) 10%, var(--border-strong) 90%, transparent);
      }

      .split-line-h {
        left: 0; right: 0; top: 50%;
        height: 1px;
        background: linear-gradient(to right, transparent, var(--border-strong) 10%, var(--border-strong) 90%, transparent);
      }

      /* ══════════════════════════════════════ */
      /* SHARED PANEL STYLES                   */
      /* ══════════════════════════════════════ */
      .panel-label {
        display: flex; align-items: center; gap: 1rem;
        font-size: 0.68rem; font-weight: 500; letter-spacing: 0.2em;
        text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 2.5rem;
      }

      .label-num { font-family: var(--font-display); font-size: 0.8rem; color: var(--bronze); }
      .label-line { width: 35px; height: 1px; background: var(--stone); }

      .panel-quote {
        font-family: var(--font-display);
        font-size: clamp(1.3rem, 2.2vw, 2rem);
        font-style: italic; line-height: 1.5; margin-bottom: 1.5rem; max-width: 440px;
      }

      .panel-heading {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 5vw, 4.5rem);
        font-weight: 400; line-height: 1.05; margin-bottom: 1.5rem;
      }

      .panel-body {
        font-size: 0.88rem; line-height: 1.8; color: var(--text-secondary);
        font-weight: 300; max-width: 400px;
      }

      /* ── VISUAL BLOCKS ── */
      .visual-block {
        width: 100%; max-width: 380px; aspect-ratio: 4/3;
        position: relative; margin: 0 auto;
      }

      /* Facade */
      .block-facade {
        border: 1px solid var(--border-strong);
        display: grid; grid-template-columns: repeat(3, 1fr);
        grid-template-rows: repeat(2, 1fr); gap: 12px; padding: 24px;
      }
      .facade-window {
        border: 1px solid rgba(26,26,26,0.1);
        background: linear-gradient(135deg, rgba(212,205,196,0.3), rgba(212,205,196,0.1));
        position: relative;
      }
      .facade-window::after {
        content: ''; position: absolute; width: 50%; height: 1px;
        background: var(--border); bottom: 30%; left: 25%;
      }
      .facade-beam { position: absolute; left: 0; right: 0; height: 3px; background: rgba(26,26,26,0.06); top: 50%; }
      .facade-beam-2 { top: auto; bottom: 0; height: 6px; background: rgba(26,26,26,0.08); }

      /* Section */
      .block-section { border-bottom: 2px solid rgba(26,26,26,0.15); }
      .section-floor { position: absolute; left: 10%; right: 10%; height: 1px; background: rgba(26,26,26,0.12); }
      .section-floor-1 { bottom: 25%; } .section-floor-2 { bottom: 50%; } .section-floor-3 { bottom: 75%; }
      .section-col { position: absolute; bottom: 0; width: 4px; height: 90%; background: rgba(26,26,26,0.08); }
      .section-col-1 { left: 30%; } .section-col-2 { right: 30%; }
      .section-roof { position: absolute; top: 5%; left: 5%; right: 5%; height: 3px; background: rgba(139,115,53,0.15); }

      /* Plan */
      .block-plan { border: 2px solid rgba(26,26,26,0.1); }
      .plan-room { position: absolute; border: 1px solid rgba(26,26,26,0.08); }
      .plan-room-1 { top: 8%; left: 8%; width: 45%; height: 55%; }
      .plan-room-2 { top: 8%; right: 8%; width: 35%; height: 40%; }
      .plan-room-3 { bottom: 8%; left: 8%; width: 84%; height: 30%; border-color: rgba(139,115,53,0.12); }
      .plan-wall { position: absolute; background: rgba(26,26,26,0.1); }
      .plan-wall-1 { left: 53%; top: 8%; width: 2px; height: 55%; }
      .plan-wall-2 { top: 63%; left: 8%; width: 84%; height: 2px; }
      .plan-wall-3 { top: 48%; right: 8%; width: 35%; height: 2px; }
      .plan-door { position: absolute; bottom: 28%; left: 30%; width: 18px; height: 4px; background: var(--cream); border-bottom: 1px dashed rgba(139,115,53,0.2); }

      /* Elevation */
      .block-elevation { border-bottom: 2px solid rgba(26,26,26,0.12); }
      .elev-base { position: absolute; bottom: 0; left: 15%; right: 15%; height: 8px; background: rgba(26,26,26,0.06); }
      .elev-floor { position: absolute; left: 15%; right: 15%; height: 1px; background: rgba(26,26,26,0.1); }
      .elev-floor-1 { bottom: 25%; } .elev-floor-2 { bottom: 50%; } .elev-floor-3 { bottom: 75%; right: 25%; }
      .elev-cantilever { position: absolute; bottom: 50%; right: 10%; width: 20%; height: 25%; border: 1px solid rgba(26,26,26,0.08); border-bottom: 2px solid rgba(139,115,53,0.12); }
      .elev-glass { position: absolute; bottom: 26%; left: 20%; width: 25%; height: 22%; background: linear-gradient(180deg, rgba(212,205,196,0.2), rgba(212,205,196,0.05)); border: 1px solid rgba(26,26,26,0.05); }
      .elev-glass-2 { left: 50%; width: 18%; }

      /* Detail */
      .block-detail { border: 1px dashed rgba(26,26,26,0.08); }
      .detail-beam { position: absolute; top: 40%; left: 10%; right: 10%; height: 12px; border: 1px solid rgba(26,26,26,0.1); background: rgba(212,205,196,0.15); }
      .detail-beam-2 { top: auto; bottom: 35%; left: 25%; right: 25%; height: 8px; transform: rotate(-2deg); }
      .detail-joint { position: absolute; top: 38%; left: 45%; width: 20px; height: 20px; border: 2px solid rgba(139,115,53,0.2); border-radius: 50%; }
      .detail-bolt { position: absolute; top: 43%; left: 25%; width: 6px; height: 6px; background: rgba(26,26,26,0.15); border-radius: 50%; }
      .detail-bolt-2 { left: auto; right: 25%; }
      .detail-line { position: absolute; background: rgba(139,115,53,0.1); }
      .detail-line-1 { top: 20%; left: 30%; width: 1px; height: 15%; }
      .detail-line-2 { bottom: 20%; right: 30%; width: 15%; height: 1px; }
      .detail-dimension { position: absolute; bottom: 15%; left: 20%; right: 20%; height: 1px; background: rgba(139,115,53,0.15); }
      .detail-dimension::before, .detail-dimension::after { content: ''; position: absolute; width: 1px; height: 8px; background: rgba(139,115,53,0.15); top: -4px; }
      .detail-dimension::before { left: 0; } .detail-dimension::after { right: 0; }

      /* ── AWARDS ── */
      .awards-compact { display: flex; flex-direction: column; }
      .award-line {
        padding: 0.9rem 0; border-bottom: 1px solid var(--border);
        font-size: 0.85rem; display: flex; align-items: baseline; gap: 1.5rem;
      }
      .award-line:first-child { border-top: 1px solid var(--border); }
      .award-yr { font-family: var(--font-display); font-size: 0.8rem; color: var(--bronze); flex-shrink: 0; width: 40px; }

      /* ── PROCESS ── */
      .process-list { display: flex; flex-direction: column; gap: 2.5rem; }
      .process-item { display: flex; gap: 1.5rem; align-items: flex-start; }
      .process-num { font-family: var(--font-display); font-size: 1.5rem; color: var(--bronze); opacity: 0.4; line-height: 1; flex-shrink: 0; padding-top: 0.15rem; }
      .process-item h3 { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.3em; margin-bottom: 0.4rem; }
      .process-item p { font-size: 0.82rem; line-height: 1.7; color: var(--text-secondary); font-weight: 300; }

      /* ══ CONTACT ══ */
      .contact-section { padding: 8rem 4rem; background: var(--charcoal); color: var(--cream); }
      .contact-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: start; }
      .contact-headline { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 400; line-height: 1.25; color: var(--cream); }
      .contact-right { display: flex; flex-direction: column; gap: 2rem; }
      .contact-label { font-size: 0.6rem; font-weight: 600; letter-spacing: 0.3em; text-transform: uppercase; color: #a8903e; display: block; margin-bottom: 0.4rem; }
      .contact-block p { font-size: 0.88rem; line-height: 1.7; color: rgba(245,242,237,0.6); font-weight: 300; }
      .contact-footer { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid rgba(245,242,237,0.08); }
      .contact-footer span { font-size: 0.68rem; color: rgba(245,242,237,0.3); letter-spacing: 0.05em; }

      /* ── RESPONSIVE ── */
      @media (max-width: 900px) {
        .site-nav { padding: 1.5rem 2rem; }
        .nav-meta { display: none; }
        .vsplit { grid-template-columns: 1fr; }
        .vsplit-left, .vsplit-right { min-height: 60vh; padding: 5vh 6vw; }
        .hsplit { grid-template-rows: 1fr 1fr; }
        .hsplit-top, .hsplit-bottom { padding: 5vh 6vw; min-height: 40vh; }
        .split-line-v { display: none; }
        .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
        .contact-section { padding: 5rem 2rem; }
      }
    </style>

    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      // ── LENIS — extra smooth ──
      const lenis = new Lenis({
        duration: 1.8,
        easing: (t: number) => 1 - Math.pow(1 - t, 4),
        smoothWheel: true,
        touchMultiplier: 1.5,
      });

      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time: number) => { lenis.raf(time * 1000); });
      gsap.ticker.lagSmoothing(0);

      // ── HERO FADE ──
      gsap.to('.hero-content', {
        y: -60, opacity: 0,
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 2 },
      });

      gsap.to('.hero-grid-lines', {
        y: -30, opacity: 0,
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 2 },
      });

      // ── VERTICAL SPLITS ──
      document.querySelectorAll('.vsplit').forEach((section) => {
        const left = section.querySelector('.vsplit-left') as HTMLElement;
        const right = section.querySelector('.vsplit-right') as HTMLElement;
        const isReversed = section.classList.contains('vsplit-reversed');

        if (!left || !right) return;

        const distance = 120;

        // One side slides up, the other slides down
        gsap.fromTo(isReversed ? right : left,
          { y: distance },
          {
            y: -distance * 0.3,
            ease: 'none',
            scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 2 },
          }
        );

        gsap.fromTo(isReversed ? left : right,
          { y: -distance },
          {
            y: distance * 0.3,
            ease: 'none',
            scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 2 },
          }
        );
      });

      // ── HORIZONTAL SPLITS ──
      document.querySelectorAll('.hsplit').forEach((section) => {
        const top = section.querySelector('.hsplit-top') as HTMLElement;
        const bottom = section.querySelector('.hsplit-bottom') as HTMLElement;
        const isReversed = section.classList.contains('hsplit-reversed');

        if (!top || !bottom) return;

        const distance = 100;

        // One side slides left, the other slides right
        gsap.fromTo(isReversed ? bottom : top,
          { x: distance },
          {
            x: -distance * 0.3,
            ease: 'none',
            scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 2 },
          }
        );

        gsap.fromTo(isReversed ? top : bottom,
          { x: -distance },
          {
            x: distance * 0.3,
            ease: 'none',
            scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 2 },
          }
        );
      });

      // ── CONTENT REVEALS ──
      const revealEls = document.querySelectorAll('.panel-label, .panel-quote, .panel-heading, .panel-body, .award-line, .process-item, .visual-block, .contact-headline, .contact-block');

      revealEls.forEach((el, i) => {
        gsap.from(el, {
          opacity: 0,
          y: 25,
          duration: 0.9,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: el,
            start: 'top 88%',
            toggleActions: 'play none none none',
          },
        });
      });
    </script>

  </body>
</html>
