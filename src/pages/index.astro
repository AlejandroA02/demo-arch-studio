    <!-- Fixed nav -->
    <nav class="site-nav">
      <div class="nav-brand">ATELIER</div>
      <div class="nav-meta">Architecture & Interior Design</div>
    </nav>

    <!-- ══════ 1. HERO ══════ -->
    <section class="hero">
      <div class="hero-grid-lines">
        <div class="hgl hgl-v1"></div>
        <div class="hgl hgl-v2"></div>
        <div class="hgl hgl-v3"></div>
        <div class="hgl hgl-h1"></div>
        <div class="hgl hgl-h2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-eyebrow">Est. 2019 — Miami, FL</div>
        <h1 class="hero-title">ATELIER</h1>
        <p class="hero-sub">We shape space. Space shapes life.</p>
        <div class="hero-scroll-cue">
          <span>Scroll</span>
          <div class="scroll-bar"><div class="scroll-bar-fill"></div></div>
        </div>
      </div>
    </section>

    <!-- ══════ 2. VERTICAL SPLIT — Philosophy + Luxury Residence Floor Plan ══════ -->
    <section class="vsplit" data-split="vertical">
      <div class="vsplit-left">
        <div class="panel-label">
          <span class="label-num">01</span>
          <span class="label-line"></span>
          <span>Philosophy</span>
        </div>
        <blockquote class="panel-quote">
          &ldquo;Architecture should speak of its time and place, but yearn for timelessness.&rdquo;
        </blockquote>
        <p class="panel-body">We believe in the quiet power of considered space. Every line we draw serves the dialogue between structure and the human experience within it.</p>
      </div>
      <div class="vsplit-right">
        <div class="blueprint-container">
