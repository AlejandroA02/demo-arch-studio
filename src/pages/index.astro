    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from 'lenis';

      gsap.registerPlugin(ScrollTrigger);

      // ── LENIS ──
      const lenis = new Lenis({
        duration: 1.8,
        easing: (t: number) => 1 - Math.pow(1 - t, 4),
        smoothWheel: true,
        touchMultiplier: 1.5,
      });
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time: number) => { lenis.raf(time * 1000); });
      gsap.ticker.lagSmoothing(0);

      // ── HERO FADE ──
      gsap.to('.hero-content', {
        y: -60, opacity: 0,
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 2 },
      });
      gsap.to('.hero-grid-lines', {
        y: -30, opacity: 0,
        scrollTrigger: { trigger: '.hero', start: 'top top', end: 'bottom top', scrub: 2 },
      });

      // ── VERTICAL SPLITS ──
      document.querySelectorAll('.vsplit').forEach((section) => {
        const left = section.querySelector('.vsplit-left') as HTMLElement;
        const right = section.querySelector('.vsplit-right') as HTMLElement;
        const isReversed = section.classList.contains('vsplit-reversed');
        if (!left || !right) return;
        const distance = 120;

        gsap.fromTo(isReversed ? right : left,
          { y: distance }, { y: -distance * 0.3, ease: 'none',
            scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 2 },
        });
        gsap.fromTo(isReversed ? left : right,
          { y: -distance }, { y: distance * 0.3, ease: 'none',
            scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 2 },
        });
      });

      // ── HORIZONTAL SPLITS ──
      document.querySelectorAll('.hsplit').forEach((section) => {
        const top = section.querySelector('.hsplit-top') as HTMLElement;
        const bottom = section.querySelector('.hsplit-bottom') as HTMLElement;
        const isReversed = section.classList.contains('hsplit-reversed');
        if (!top || !bottom) return;
        const distance = 100;

        gsap.fromTo(isReversed ? bottom : top,
          { x: distance }, { x: -distance * 0.3, ease: 'none',
            scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 2 },
        });
        gsap.fromTo(isReversed ? top : bottom,
          { x: -distance }, { x: distance * 0.3, ease: 'none',
            scrollTrigger: { trigger: section, start: 'top bottom', end: 'bottom top', scrub: 2 },
        });
      });

      // ── BLUEPRINT LINE-DRAWING ANIMATION ──
      document.querySelectorAll('[data-blueprint]').forEach((svg) => {
        const drawables = svg.querySelectorAll('line, rect, path, circle');
        const dots = svg.querySelectorAll('.bp-dot');

        drawables.forEach((el, i) => {
          const elem = el as SVGGeometryElement;
          if (elem.classList.contains('bp-dot')) return;

          // Calculate actual path length
          let length = 2000;
          try { length = elem.getTotalLength(); } catch(e) { /* fallback */ }

          gsap.set(elem, { strokeDasharray: length, strokeDashoffset: length });

          gsap.to(elem, {
            strokeDashoffset: 0,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: svg.closest('.blueprint-container'),
              start: 'top 85%',
              end: 'top 25%',
              scrub: 1.5,
            },
            delay: i * 0.02,
          });
        });

        // Fade in dots and text
        const fadeEls = svg.querySelectorAll('.bp-dot, .bp-text, .bp-text-dim, .bp-text-accent, .bp-text-grid');
        fadeEls.forEach((el, i) => {
          gsap.to(el, {
            opacity: el.classList.contains('bp-dot') ? 1 : el.classList.contains('bp-text-dim') ? 0.8 : 1,
            duration: 0.4,
            scrollTrigger: {
              trigger: svg.closest('.blueprint-container'),
              start: 'top 40%',
              toggleActions: 'play none none none',
            },
            delay: i * 0.06,
          });
        });
      });

      // ── CONTENT REVEALS ──
      document.querySelectorAll('.panel-label, .panel-quote, .panel-heading, .panel-body, .award-line, .process-item, .contact-headline, .contact-block').forEach((el) => {
        gsap.from(el, {
          opacity: 0, y: 25, duration: 0.9, ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
        });
      });
    </script>

  </body>
</html>
