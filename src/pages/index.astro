---

---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ATELIER — Architecture Studio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,700;1,6..96,400&family=Karla:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Navigation -->
    <nav class="site-nav">
      <div class="nav-brand">ATELIER</div>
      <div class="nav-links">
        <span class="nav-link">Philosophy</span>
        <span class="nav-link">Projects</span>
        <span class="nav-link">Process</span>
        <span class="nav-link">Contact</span>
      </div>
    </nav>

    <!-- Slide Counter -->
    <div class="slide-counter">
      <span class="counter-current">01</span>
      <span class="counter-divider"></span>
      <span class="counter-total">06</span>
    </div>

    <!-- Swiper -->
    <div class="swiper">
      <div class="swiper-wrapper">

        <!-- ══════ SLIDE 1: HERO ══════ -->
        <div class="swiper-slide slide-hero">
          <div class="slide-inner">
            <!-- Architectural line drawing -->
            <div class="arch-drawing" data-swiper-parallax="-200">
              <div class="arch-line arch-rect-1"></div>
              <div class="arch-line arch-rect-2"></div>
              <div class="arch-line arch-rect-3"></div>
              <div class="arch-line arch-rect-4"></div>
              <div class="arch-line arch-rect-5"></div>
              <div class="arch-line arch-h-1"></div>
              <div class="arch-line arch-h-2"></div>
              <div class="arch-line arch-h-3"></div>
              <div class="arch-line arch-v-1"></div>
              <div class="arch-line arch-v-2"></div>
              <div class="arch-line arch-v-3"></div>
              <div class="arch-line arch-v-4"></div>
              <div class="arch-line arch-cross-1"></div>
              <div class="arch-line arch-cross-2"></div>
            </div>

            <div class="hero-content" data-swiper-parallax="-100">
              <div class="hero-eyebrow">Architecture & Interior Design</div>
              <h1 class="hero-title">ATELIER</h1>
              <div class="hero-sub">
                <span class="hero-dash"></span>
                <span>Est. 2019 — Miami, FL</span>
              </div>
            </div>

            <div class="hero-scroll-hint">
              <span>Scroll to explore</span>
              <div class="scroll-line"></div>
            </div>
          </div>
        </div>

        <!-- ══════ SLIDE 2: PHILOSOPHY ══════ -->
        <div class="swiper-slide slide-philosophy">
          <div class="slide-inner">
            <div class="philosophy-layout">
              <div class="philosophy-left" data-swiper-parallax="-150">
                <div class="section-label">
                  <span class="label-num">02</span>
                  <span class="label-line"></span>
                  <span>Philosophy</span>
                </div>
                <blockquote class="philosophy-quote">
                  <span class="quote-mark">&ldquo;</span>
                  Architecture should speak of its time and place, but yearn for timelessness.
                </blockquote>
                <p class="philosophy-body">
                  We believe in the quiet power of considered space. Every line we draw, every material we choose, serves the dialogue between structure and the human experience within it. Our work strips away the unnecessary to reveal what is essential.
                </p>
              </div>
              <div class="philosophy-divider"></div>
              <div class="philosophy-right" data-swiper-parallax="-300">
                <div class="geo-composition">
                  <div class="geo-rect geo-rect-1"></div>
                  <div class="geo-rect geo-rect-2"></div>
                  <div class="geo-rect geo-rect-3"></div>
                  <div class="geo-line geo-line-1"></div>
                  <div class="geo-line geo-line-2"></div>
                  <div class="geo-circle"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ══════ SLIDE 3: PROJECTS ══════ -->
        <div class="swiper-slide slide-projects">
          <div class="slide-inner">
            <div class="section-label projects-label" data-swiper-parallax="-80">
              <span class="label-num">03</span>
              <span class="label-line"></span>
              <span>Selected Work</span>
            </div>
            <div class="projects-grid" data-swiper-parallax="-150">
              <div class="project-card">
                <div class="project-thumb thumb-1">
                  <div class="thumb-overlay">
                    <span>View</span>
                  </div>
                </div>
                <div class="project-info">
                  <h3>Meridian House</h3>
                  <span class="project-meta">Miami Beach, FL — 2024</span>
                </div>
              </div>
              <div class="project-card">
                <div class="project-thumb thumb-2">
                  <div class="thumb-overlay">
                    <span>View</span>
                  </div>
                </div>
                <div class="project-info">
                  <h3>Luma Pavilion</h3>
                  <span class="project-meta">Coral Gables, FL — 2023</span>
                </div>
              </div>
              <div class="project-card">
                <div class="project-thumb thumb-3">
                  <div class="thumb-overlay">
                    <span>View</span>
                  </div>
                </div>
                <div class="project-info">
                  <h3>Terra Office Tower</h3>
                  <span class="project-meta">Brickell, FL — 2023</span>
                </div>
              </div>
              <div class="project-card">
                <div class="project-thumb thumb-4">
                  <div class="thumb-overlay">
                    <span>View</span>
                  </div>
                </div>
                <div class="project-info">
                  <h3>Solace Residence</h3>
                  <span class="project-meta">Key Biscayne, FL — 2022</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ══════ SLIDE 4: PROCESS ══════ -->
        <div class="swiper-slide slide-process">
          <div class="slide-inner">
            <div class="section-label process-label" data-swiper-parallax="-80">
              <span class="label-num">04</span>
              <span class="label-line"></span>
              <span>Our Process</span>
            </div>
            <div class="process-steps" data-swiper-parallax="-200">
              <div class="process-step">
                <div class="step-icon">
                  <div class="icon-concept"></div>
                </div>
                <div class="step-num">01</div>
                <h3 class="step-title">CONCEPT</h3>
                <p class="step-desc">Listening, researching, and distilling the essence of the project into a clear vision.</p>
              </div>
              <div class="process-connector">
                <div class="connector-line"></div>
                <div class="connector-arrow"></div>
              </div>
              <div class="process-step">
                <div class="step-icon">
                  <div class="icon-design"></div>
                </div>
                <div class="step-num">02</div>
                <h3 class="step-title">DESIGN</h3>
                <p class="step-desc">Translating ideas into precise drawings, models, and material palettes.</p>
              </div>
              <div class="process-connector">
                <div class="connector-line"></div>
                <div class="connector-arrow"></div>
              </div>
              <div class="process-step">
                <div class="step-icon">
                  <div class="icon-build"></div>
                </div>
                <div class="step-num">03</div>
                <h3 class="step-title">BUILD</h3>
                <p class="step-desc">Overseeing every detail from foundation to finish with uncompromising craft.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- ══════ SLIDE 5: AWARDS ══════ -->
        <div class="swiper-slide slide-awards">
          <div class="slide-inner">
            <div class="section-label awards-label" data-swiper-parallax="-80">
              <span class="label-num">05</span>
              <span class="label-line"></span>
              <span>Recognition</span>
            </div>
            <div class="awards-list" data-swiper-parallax="-180">
              <div class="award-row">
                <span class="award-year">2024</span>
                <span class="award-name">AIA Miami Honor Award</span>
                <span class="award-project">Meridian House</span>
              </div>
              <div class="award-row">
                <span class="award-year">2024</span>
                <span class="award-name">Architizer A+ Jury Winner</span>
                <span class="award-project">Luma Pavilion</span>
              </div>
              <div class="award-row">
                <span class="award-year">2023</span>
                <span class="award-name">Interior Design Best of Year</span>
                <span class="award-project">Terra Office Tower</span>
              </div>
              <div class="award-row">
                <span class="award-year">2023</span>
                <span class="award-name">Azure Magazine AZ Award</span>
                <span class="award-project">Solace Residence</span>
              </div>
              <div class="award-row">
                <span class="award-year">2022</span>
                <span class="award-name">Dezeen Awards Longlist</span>
                <span class="award-project">Solace Residence</span>
              </div>
              <div class="award-row">
                <span class="award-year">2022</span>
                <span class="award-name">AIA Florida Merit Award</span>
                <span class="award-project">Civic Arts Center</span>
              </div>
              <div class="award-row">
                <span class="award-year">2021</span>
                <span class="award-name">Design Miami/ Emerging Studio</span>
                <span class="award-project">Studio Recognition</span>
              </div>
            </div>
          </div>
        </div>

        <!-- ══════ SLIDE 6: CONTACT ══════ -->
        <div class="swiper-slide slide-contact">
          <div class="slide-inner">
            <div class="contact-layout">
              <div class="contact-left" data-swiper-parallax="-120">
                <div class="section-label">
                  <span class="label-num">06</span>
                  <span class="label-line"></span>
                  <span>Get in Touch</span>
                </div>
                <h2 class="contact-headline">Let&rsquo;s build<br/>something<br/>extraordinary.</h2>
              </div>
              <div class="contact-right" data-swiper-parallax="-250">
                <div class="contact-block">
                  <span class="contact-label">Studio</span>
                  <p>3400 NW 2nd Avenue<br/>Suite 210<br/>Miami, FL 33127</p>
                </div>
                <div class="contact-block">
                  <span class="contact-label">Email</span>
                  <p>hello@atelier.studio</p>
                </div>
                <div class="contact-block">
                  <span class="contact-label">Phone</span>
                  <p>+1 (305) 555-0172</p>
                </div>
                <div class="contact-footer">
                  <span>&copy; 2024 Atelier Architecture Studio</span>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Pagination -->
      <div class="swiper-pagination"></div>
    </div>

    <!-- ═══════════════════════════════════════════ -->
    <!-- STYLES                                     -->
    <!-- ═══════════════════════════════════════════ -->
    <style is:global>
      @import 'swiper/css';
      @import 'swiper/css/pagination';
      @import 'swiper/css/parallax';

      /* ──── RESET & TOKENS ──── */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --cream: #f5f2ed;
        --stone: #d4cdc4;
        --stone-light: #e8e4de;
        --charcoal: #1a1a1a;
        --charcoal-soft: #2d2d2d;
        --bronze: #8b7335;
        --bronze-light: #a8903e;
        --text-primary: #1a1a1a;
        --text-secondary: #6b6560;
        --text-tertiary: #9e9790;
        --border: rgba(26, 26, 26, 0.08);
        --border-strong: rgba(26, 26, 26, 0.15);
        --font-display: 'Bodoni Moda', 'Georgia', serif;
        --font-body: 'Karla', 'Helvetica Neue', sans-serif;
      }

      html, body {
        height: 100%;
        overflow: hidden;
        background: var(--cream);
        color: var(--text-primary);
        font-family: var(--font-body);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* ──── SUBTLE PAPER TEXTURE ──── */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 10000;
        pointer-events: none;
        opacity: 0.02;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 200px 200px;
      }

      /* ──── NAVIGATION ──── */
      .site-nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem 3.5rem;
        pointer-events: none;
      }

      .nav-brand {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 400;
        letter-spacing: 0.35em;
        color: var(--text-primary);
        pointer-events: auto;
      }

      .nav-links {
        display: flex;
        gap: 2.5rem;
        pointer-events: auto;
      }

      .nav-link {
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-secondary);
        cursor: pointer;
        transition: color 0.3s ease;
        position: relative;
      }

      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--bronze);
        transition: width 0.3s ease;
      }

      .nav-link:hover {
        color: var(--text-primary);
      }

      .nav-link:hover::after {
        width: 100%;
      }

      /* ──── SLIDE COUNTER ──── */
      .slide-counter {
        position: fixed;
        left: 3.5rem;
        bottom: 3rem;
        z-index: 100;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-family: var(--font-body);
        font-size: 0.7rem;
        font-weight: 400;
        letter-spacing: 0.15em;
        color: var(--text-tertiary);
      }

      .counter-divider {
        width: 24px;
        height: 1px;
        background: var(--stone);
      }

      /* ──── SWIPER ──── */
      .swiper {
        width: 100%;
        height: 100vh;
      }

      .swiper-slide {
        overflow: hidden;
        background: var(--cream);
      }

      .slide-inner {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 6rem 8vw;
      }

      /* Pagination */
      .swiper-pagination {
        right: 3rem !important;
        left: auto !important;
        display: flex;
        flex-direction: column;
        gap: 12px;
        align-items: center;
      }

      .swiper-pagination-bullet {
        width: 6px !important;
        height: 6px !important;
        background: var(--stone) !important;
        opacity: 1 !important;
        border-radius: 50% !important;
        transition: all 0.4s ease !important;
      }

      .swiper-pagination-bullet-active {
        background: var(--bronze) !important;
        height: 24px !important;
        border-radius: 3px !important;
      }

      /* ──── SECTION LABELS ──── */
      .section-label {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        margin-bottom: 3rem;
      }

      .label-num {
        font-family: var(--font-display);
        font-size: 0.8rem;
        color: var(--bronze);
      }

      .label-line {
        width: 40px;
        height: 1px;
        background: var(--stone);
      }

      /* ═══════════════════════════════════════════ */
      /* SLIDE 1: HERO                              */
      /* ═══════════════════════════════════════════ */
      .slide-hero .slide-inner {
        position: relative;
        align-items: center;
        justify-content: center;
      }

      /* Architectural line drawing */
      .arch-drawing {
        position: absolute;
        inset: 0;
        overflow: hidden;
      }

      .arch-line {
        position: absolute;
        border: 1px solid rgba(26, 26, 26, 0.06);
      }

      .arch-rect-1 {
        width: 45%;
        height: 70%;
        top: 15%;
        left: 30%;
      }

      .arch-rect-2 {
        width: 25%;
        height: 45%;
        top: 28%;
        left: 38%;
        border-color: rgba(139, 115, 53, 0.1);
      }

      .arch-rect-3 {
        width: 55%;
        height: 35%;
        bottom: 20%;
        left: 22%;
      }

      .arch-rect-4 {
        width: 15%;
        height: 55%;
        top: 22%;
        right: 18%;
        border-color: rgba(26, 26, 26, 0.04);
      }

      .arch-rect-5 {
        width: 35%;
        height: 25%;
        top: 10%;
        left: 10%;
        border-color: rgba(26, 26, 26, 0.03);
      }

      .arch-h-1 {
        width: 70%;
        height: 0;
        top: 40%;
        left: 15%;
        border-bottom: 1px solid rgba(26, 26, 26, 0.04);
      }

      .arch-h-2 {
        width: 50%;
        height: 0;
        top: 60%;
        left: 25%;
        border-bottom: 1px solid rgba(139, 115, 53, 0.06);
      }

      .arch-h-3 {
        width: 40%;
        height: 0;
        top: 75%;
        left: 30%;
        border-bottom: 1px solid rgba(26, 26, 26, 0.03);
      }

      .arch-v-1 {
        width: 0;
        height: 60%;
        top: 20%;
        left: 25%;
        border-right: 1px solid rgba(26, 26, 26, 0.04);
      }

      .arch-v-2 {
        width: 0;
        height: 45%;
        top: 30%;
        left: 50%;
        border-right: 1px solid rgba(26, 26, 26, 0.05);
      }

      .arch-v-3 {
        width: 0;
        height: 50%;
        top: 25%;
        right: 30%;
        border-right: 1px solid rgba(139, 115, 53, 0.04);
      }

      .arch-v-4 {
        width: 0;
        height: 35%;
        top: 35%;
        left: 40%;
        border-right: 1px solid rgba(26, 26, 26, 0.03);
      }

      .arch-cross-1 {
        width: 80px;
        height: 80px;
        top: 30%;
        left: 55%;
        border: none;
        background:
          linear-gradient(rgba(139, 115, 53, 0.08), rgba(139, 115, 53, 0.08)) center/1px 100% no-repeat,
          linear-gradient(rgba(139, 115, 53, 0.08), rgba(139, 115, 53, 0.08)) center/100% 1px no-repeat;
      }

      .arch-cross-2 {
        width: 50px;
        height: 50px;
        bottom: 30%;
        left: 35%;
        border: none;
        background:
          linear-gradient(var(--border), var(--border)) center/1px 100% no-repeat,
          linear-gradient(var(--border), var(--border)) center/100% 1px no-repeat;
      }

      .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
      }

      .hero-eyebrow {
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        margin-bottom: 1.5rem;
      }

      .hero-title {
        font-family: var(--font-display);
        font-size: clamp(5rem, 14vw, 13rem);
        font-weight: 400;
        letter-spacing: 0.15em;
        line-height: 0.85;
        color: var(--charcoal);
        margin-bottom: 2rem;
      }

      .hero-sub {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        font-size: 0.75rem;
        letter-spacing: 0.15em;
        color: var(--text-secondary);
      }

      .hero-dash {
        width: 30px;
        height: 1px;
        background: var(--bronze);
      }

      .hero-scroll-hint {
        position: absolute;
        bottom: 3rem;
        right: 0;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-tertiary);
      }

      .scroll-line {
        width: 40px;
        height: 1px;
        background: var(--stone);
        position: relative;
        overflow: hidden;
      }

      .scroll-line::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: var(--bronze);
        animation: scroll-hint 2s ease-in-out infinite;
      }

      @keyframes scroll-hint {
        0% { left: -100%; }
        50% { left: 0; }
        100% { left: 100%; }
      }

      /* ═══════════════════════════════════════════ */
      /* SLIDE 2: PHILOSOPHY                        */
      /* ═══════════════════════════════════════════ */
      .philosophy-layout {
        display: grid;
        grid-template-columns: 1fr 1px 1fr;
        gap: 5vw;
        align-items: center;
        height: 100%;
        max-width: 1200px;
        margin: 0 auto;
      }

      .philosophy-divider {
        width: 1px;
        height: 60%;
        background: linear-gradient(to bottom, transparent, var(--stone), transparent);
        align-self: center;
      }

      .quote-mark {
        font-family: var(--font-display);
        font-size: 5rem;
        line-height: 0;
        color: var(--bronze);
        opacity: 0.4;
        display: block;
        margin-bottom: 1rem;
      }

      .philosophy-quote {
        font-family: var(--font-display);
        font-size: clamp(1.4rem, 2.5vw, 2.2rem);
        font-weight: 400;
        font-style: italic;
        line-height: 1.5;
        color: var(--charcoal);
        margin-bottom: 2rem;
      }

      .philosophy-body {
        font-size: 0.88rem;
        line-height: 1.8;
        color: var(--text-secondary);
        font-weight: 300;
        max-width: 420px;
      }

      /* Geometric composition */
      .geo-composition {
        position: relative;
        width: 100%;
        height: 400px;
      }

      .geo-rect {
        position: absolute;
        border: 1px solid var(--border-strong);
      }

      .geo-rect-1 {
        width: 200px;
        height: 280px;
        top: 10%;
        left: 15%;
        background: linear-gradient(135deg, rgba(212, 205, 196, 0.3), transparent);
      }

      .geo-rect-2 {
        width: 160px;
        height: 160px;
        top: 30%;
        left: 40%;
        border-color: var(--bronze);
        opacity: 0.2;
      }

      .geo-rect-3 {
        width: 120px;
        height: 200px;
        bottom: 5%;
        right: 15%;
        background: linear-gradient(180deg, rgba(139, 115, 53, 0.05), rgba(212, 205, 196, 0.15));
      }

      .geo-line {
        position: absolute;
      }

      .geo-line-1 {
        width: 80%;
        height: 1px;
        background: var(--border);
        top: 50%;
        left: 10%;
      }

      .geo-line-2 {
        width: 1px;
        height: 60%;
        background: var(--border);
        top: 20%;
        left: 55%;
      }

      .geo-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        border: 1px solid rgba(139, 115, 53, 0.15);
        position: absolute;
        top: 25%;
        right: 25%;
      }

      /* ═══════════════════════════════════════════ */
      /* SLIDE 3: PROJECTS                          */
      /* ═══════════════════════════════════════════ */
      .slide-projects .slide-inner {
        padding-top: 8rem;
      }

      .projects-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        max-width: 1200px;
      }

      .project-card {
        cursor: pointer;
      }

      .project-thumb {
        aspect-ratio: 3/4;
        position: relative;
        overflow: hidden;
        margin-bottom: 1rem;
      }

      .thumb-1 {
        background: linear-gradient(145deg, #c8c0b4, #a69e92, #d4cdc4);
      }

      .thumb-1::before {
        content: '';
        position: absolute;
        inset: 15%;
        border: 1px solid rgba(255,255,255,0.2);
      }

      .thumb-1::after {
        content: '';
        position: absolute;
        width: 60%;
        height: 1px;
        background: rgba(255,255,255,0.15);
        top: 50%;
        left: 20%;
      }

      .thumb-2 {
        background: linear-gradient(160deg, #b8b0a4, #8e8578, #c4bdb4);
      }

      .thumb-2::before {
        content: '';
        position: absolute;
        width: 40%;
        height: 60%;
        bottom: 10%;
        right: 15%;
        border: 1px solid rgba(255,255,255,0.15);
      }

      .thumb-3 {
        background: linear-gradient(135deg, #d0c8bc, #9e9588, #c0b8ac);
      }

      .thumb-3::before {
        content: '';
        position: absolute;
        inset: 20%;
        border-bottom: 1px solid rgba(255,255,255,0.2);
        border-right: 1px solid rgba(255,255,255,0.2);
      }

      .thumb-4 {
        background: linear-gradient(170deg, #bab2a6, #a09890, #d0c8bc);
      }

      .thumb-4::before {
        content: '';
        position: absolute;
        width: 50%;
        height: 70%;
        top: 15%;
        left: 25%;
        border: 1px solid rgba(255,255,255,0.12);
      }

      .thumb-overlay {
        position: absolute;
        inset: 0;
        background: rgba(26, 26, 26, 0);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.5s ease;
      }

      .thumb-overlay span {
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: white;
        opacity: 0;
        transform: translateY(8px);
        transition: all 0.4s ease;
      }

      .project-card:hover .thumb-overlay {
        background: rgba(26, 26, 26, 0.4);
      }

      .project-card:hover .thumb-overlay span {
        opacity: 1;
        transform: translateY(0);
      }

      .project-card:hover .project-thumb {
        transform: translateY(-4px);
        transition: transform 0.4s ease;
      }

      .project-info h3 {
        font-family: var(--font-display);
        font-size: 1.05rem;
        font-weight: 400;
        margin-bottom: 0.25rem;
      }

      .project-meta {
        font-size: 0.7rem;
        color: var(--text-tertiary);
        letter-spacing: 0.05em;
      }

      /* ═══════════════════════════════════════════ */
      /* SLIDE 4: PROCESS                           */
      /* ═══════════════════════════════════════════ */
      .slide-process .slide-inner {
        align-items: flex-start;
        justify-content: center;
      }

      .process-steps {
        display: flex;
        align-items: flex-start;
        gap: 0;
        max-width: 1100px;
        margin-top: 2rem;
      }

      .process-step {
        flex: 1;
        text-align: center;
        padding: 0 2rem;
      }

      .step-icon {
        width: 64px;
        height: 64px;
        margin: 0 auto 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      /* Concept icon — circle */
      .icon-concept {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: 1.5px solid var(--charcoal);
        position: relative;
      }

      .icon-concept::after {
        content: '';
        position: absolute;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--bronze);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }

      /* Design icon — overlapping squares */
      .icon-design {
        width: 40px;
        height: 40px;
        border: 1.5px solid var(--charcoal);
        position: relative;
      }

      .icon-design::after {
        content: '';
        position: absolute;
        width: 40px;
        height: 40px;
        border: 1.5px solid var(--bronze);
        opacity: 0.4;
        top: 8px;
        left: 8px;
      }

      /* Build icon — triangle (structural) */
      .icon-build {
        width: 0;
        height: 0;
        border-left: 24px solid transparent;
        border-right: 24px solid transparent;
        border-bottom: 42px solid transparent;
        position: relative;
      }

      .icon-build::before {
        content: '';
        position: absolute;
        width: 0;
        height: 0;
        border-left: 24px solid transparent;
        border-right: 24px solid transparent;
        border-bottom: 42px solid var(--charcoal);
        top: 1.5px;
        left: -24px;
        opacity: 0.1;
      }

      .icon-build::after {
        content: '';
        position: absolute;
        width: 0;
        height: 0;
        border-left: 22px solid transparent;
        border-right: 22px solid transparent;
        border-bottom: 38px solid transparent;
        border-bottom-color: var(--cream);
        top: 5px;
        left: -22px;
      }

      .step-num {
        font-family: var(--font-display);
        font-size: 0.8rem;
        color: var(--bronze);
        margin-bottom: 0.5rem;
        letter-spacing: 0.1em;
      }

      .step-title {
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.3em;
        margin-bottom: 1rem;
      }

      .step-desc {
        font-size: 0.82rem;
        line-height: 1.7;
        color: var(--text-secondary);
        font-weight: 300;
        max-width: 260px;
        margin: 0 auto;
      }

      .process-connector {
        display: flex;
        align-items: center;
        padding-top: 2rem;
        width: 60px;
        flex-shrink: 0;
      }

      .connector-line {
        flex: 1;
        height: 1px;
        background: var(--stone);
      }

      .connector-arrow {
        width: 6px;
        height: 6px;
        border-right: 1px solid var(--text-tertiary);
        border-bottom: 1px solid var(--text-tertiary);
        transform: rotate(-45deg);
        margin-left: -3px;
      }

      /* ═══════════════════════════════════════════ */
      /* SLIDE 5: AWARDS                            */
      /* ═══════════════════════════════════════════ */
      .slide-awards .slide-inner {
        justify-content: center;
        max-width: 900px;
        margin: 0 auto;
      }

      .awards-list {
        display: flex;
        flex-direction: column;
      }

      .award-row {
        display: grid;
        grid-template-columns: 80px 1fr 200px;
        gap: 2rem;
        padding: 1.3rem 0;
        border-bottom: 1px solid var(--border);
        align-items: baseline;
        transition: background 0.3s ease;
        padding-left: 0.5rem;
        padding-right: 0.5rem;
      }

      .award-row:first-child {
        border-top: 1px solid var(--border);
      }

      .award-row:hover {
        background: rgba(139, 115, 53, 0.03);
      }

      .award-year {
        font-family: var(--font-display);
        font-size: 0.85rem;
        color: var(--bronze);
      }

      .award-name {
        font-size: 0.9rem;
        font-weight: 400;
        color: var(--text-primary);
      }

      .award-project {
        font-size: 0.78rem;
        color: var(--text-tertiary);
        text-align: right;
        font-style: italic;
      }

      /* ═══════════════════════════════════════════ */
      /* SLIDE 6: CONTACT                           */
      /* ═══════════════════════════════════════════ */
      .contact-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8vw;
        align-items: center;
        height: 100%;
        max-width: 1100px;
        margin: 0 auto;
      }

      .contact-headline {
        font-family: var(--font-display);
        font-size: clamp(2rem, 4vw, 3.5rem);
        font-weight: 400;
        line-height: 1.3;
        color: var(--charcoal);
        margin-top: 1rem;
      }

      .contact-right {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
      }

      .contact-block .contact-label {
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--bronze);
        display: block;
        margin-bottom: 0.5rem;
      }

      .contact-block p {
        font-size: 0.9rem;
        line-height: 1.7;
        color: var(--text-secondary);
        font-weight: 300;
      }

      .contact-footer {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
      }

      .contact-footer span {
        font-size: 0.7rem;
        color: var(--text-tertiary);
        letter-spacing: 0.05em;
      }

      /* ──── RESPONSIVE ──── */
      @media (max-width: 900px) {
        .site-nav {
          padding: 1.5rem 2rem;
        }

        .nav-links {
          display: none;
        }

        .slide-inner {
          padding: 5rem 5vw;
        }

        .philosophy-layout {
          grid-template-columns: 1fr;
          gap: 2rem;
        }

        .philosophy-divider {
          width: 40px;
          height: 1px;
          background: var(--stone);
        }

        .philosophy-right {
          display: none;
        }

        .projects-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 1.5rem;
        }

        .process-steps {
          flex-direction: column;
          align-items: center;
          gap: 2rem;
        }

        .process-connector {
          transform: rotate(90deg);
          width: 40px;
          padding-top: 0;
        }

        .award-row {
          grid-template-columns: 60px 1fr;
        }

        .award-project {
          display: none;
        }

        .contact-layout {
          grid-template-columns: 1fr;
          gap: 3rem;
        }

        .slide-counter {
          left: 2rem;
          bottom: 2rem;
        }

        .hero-scroll-hint {
          display: none;
        }
      }

      /* ──── GSAP ANIMATION CLASSES ──── */
      .reveal-up {
        opacity: 0;
        transform: translateY(30px);
      }

      .reveal-up.revealed {
        opacity: 1;
        transform: translateY(0);
        transition: opacity 0.8s ease, transform 0.8s ease;
      }
    </style>

    <!-- ═══════════════════════════════════════════ -->
    <!-- SCRIPTS                                    -->
    <!-- ═══════════════════════════════════════════ -->
    <script>
      import Swiper from 'swiper';
      import { Pagination, Parallax, Mousewheel, Keyboard } from 'swiper/modules';
      import { gsap } from 'gsap';

      // ──── SWIPER INIT ────
      const counterCurrent = document.querySelector('.counter-current');

      const swiper = new Swiper('.swiper', {
        modules: [Pagination, Parallax, Mousewheel, Keyboard],
        direction: 'vertical',
        loop: false,
        speed: 1000,
        parallax: true,
        grabCursor: true,
        mousewheel: {
          sensitivity: 1,
          thresholdDelta: 30,
        },
        keyboard: {
          enabled: true,
          onlyInViewport: true,
        },
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        on: {
          slideChange: function () {
            const index = this.activeIndex + 1;
            if (counterCurrent) {
              counterCurrent.textContent = String(index).padStart(2, '0');
            }
            animateSlide(this.activeIndex);
          },
          init: function () {
            animateSlide(0);
          },
        },
      });

      // ──── SLIDE ENTRANCE ANIMATIONS ────
      function animateSlide(index: number) {
        const slides = document.querySelectorAll('.swiper-slide');
        const slide = slides[index];
        if (!slide) return;

        // Reset and animate elements within the active slide
        const elements = slide.querySelectorAll('.section-label, .philosophy-quote, .philosophy-body, .project-card, .process-step, .award-row, .contact-headline, .contact-block, .hero-eyebrow, .hero-title, .hero-sub');

        elements.forEach((el, i) => {
          gsap.fromTo(el,
            { opacity: 0, y: 25 },
            {
              opacity: 1,
              y: 0,
              duration: 0.7,
              delay: 0.15 + i * 0.08,
              ease: 'power2.out',
            }
          );
        });
      }

      // ──── NAV LINK CLICK → SLIDE ────
      const navLinks = document.querySelectorAll('.nav-link');
      const slideMap: Record<string, number> = {
        'Philosophy': 1,
        'Projects': 2,
        'Process': 3,
        'Contact': 5,
      };

      navLinks.forEach((link) => {
        link.addEventListener('click', () => {
          const text = link.textContent || '';
          const slideIndex = slideMap[text];
          if (slideIndex !== undefined) {
            swiper.slideTo(slideIndex);
          }
        });
      });
    </script>

  </body>
</html>
